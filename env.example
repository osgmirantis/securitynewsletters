# ============================ Aikido ============================
# OAuth2 client credentials (scopes: teams:read, issues:read), per workspace.
# Create at: Aikido -> Settings -> Integrations -> API.

# --- Single workspace ---
AIKIDO_CLIENT_ID=AIK_CLIENT_xxxxxxxx
AIKIDO_CLIENT_SECRET=xxxxxxxxxxxxxxxx
AIKIDO_REGION=eu            # eu | us | me  (must match the workspace region)

# --- Multiple workspaces (overrides the single one above) ---
# Credentials are workspace-scoped: one Client ID/Secret per workspace.
# AIKIDO_WORKSPACES=[{"name":"Platform","region":"eu","id_env":"AIK_ID_PLATFORM","secret_env":"AIK_SECRET_PLATFORM"},{"name":"Data","region":"us","id_env":"AIK_ID_DATA","secret_env":"AIK_SECRET_DATA"}]
# AIK_ID_PLATFORM=...
# AIK_SECRET_PLATFORM=...
# AIK_ID_DATA=...
# AIK_SECRET_DATA=...

# ============================ Email ============================
# Recipients (comma-separated). To/Cc/Bcc all accepted.
EMAIL_TO=appsec@example.com,security-leads@example.com
# EMAIL_CC=cto@example.com
# EMAIL_BCC=
EMAIL_FROM=Security Newsletter <security@example.com>
# EMAIL_SUBJECT=                      # optional; default includes the date range

# --- SMTP server (any provider: Gmail, AWS SES SMTP, Mailgun, corporate relay) ---
SMTP_HOST=email-smtp.eu-west-1.amazonaws.com
SMTP_PORT=587                          # 587 = STARTTLS, 465 = SSL, 25 = none
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_SECURITY=starttls                 # starttls | ssl | none

# Cosmetic header label (single-workspace runs)
WORKSPACE_NAME=Acme Security
